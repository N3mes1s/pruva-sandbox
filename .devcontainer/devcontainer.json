{
  "name": "Pruva Reproduction Environment",
  "image": "ghcr.io/n3mes1s/pruva-sandbox@sha256:ea6708d0fd107f0a8e29b9f797987b359957f7f906ed732b95c9b72d372b8239",
  "postCreateCommand": "[ -n \"$REPRO_ID\" ] && pruva-verify \"$REPRO_ID\" || echo 'Welcome to Pruva Sandbox! Run: pruva-verify <REPRO-ID>'",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false,
      "dockerDashComposeVersion": "none"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    },
    "codespaces": {
      "openFiles": []
    }
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "PRUVA_SANDBOX": "true",
    "PRUVA_API_URL": "https://api.pruva.dev/v1",
    "PRUVA_SANDBOX_IMAGE": "ghcr.io/n3mes1s/pruva-sandbox@sha256:ea6708d0fd107f0a8e29b9f797987b359957f7f906ed732b95c9b72d372b8239",
    "PRUVA_REPRO_CACHE_DIR": "/workspaces/pruva-sandbox/.pruva-repro-cache",
    "DOCKER_API_VERSION": "1.43",
    "REPRO_ID": ""
  }
}
