--- repro/reproduction_steps.sh
+++ repro/reproduction_steps.sh
@@ -6,15 +6,25 @@
 LOGS="$ROOT/logs"
 REPRO="$ROOT/repro"
-EXTERNAL="$ROOT/external"
+if [ -n "${PRUVA_REPRO_CACHE_DIR:-}" ]; then
+    EXTERNAL="${PRUVA_REPRO_CACHE_DIR}/mapserver-rel-8-6-0-rel-8-6-1-asan-$(uname -m)-1"
+    echo "[*] Using MapServer setup cache: $EXTERNAL"
+else
+    EXTERNAL="$ROOT/external"
+fi
 mkdir -p "$LOGS" "$REPRO" "$EXTERNAL"
 
 cd "$ROOT"
 
+SUDO=""
+if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
+    SUDO="sudo"
+fi
+
 # Install dependencies if missing
 if ! command -v cmake &>/dev/null || ! dpkg -l | grep -q libgdal-dev; then
     echo "[*] Installing build dependencies..."
-    apt-get update -qq
-    apt-get install -y -qq build-essential cmake libgdal-dev libproj-dev \
+    $SUDO apt-get update -qq
+    $SUDO apt-get install -y -qq build-essential cmake libgdal-dev libproj-dev \
         libxml2-dev libgeos-dev libgif-dev libtiff-dev libsqlite3-dev \
         python3 gdal-bin
 fi
