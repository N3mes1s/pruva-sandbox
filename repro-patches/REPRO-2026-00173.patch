--- repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
+++ repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
@@ -10,6 +10,13 @@
 
 cd "$ROOT"
 
+# wolfSSL autogen.sh requires autoreconf and libtoolize.
+if ! command -v autoreconf >/dev/null 2>&1 || ! command -v libtoolize >/dev/null 2>&1; then
+    echo "[*] Installing autotools for wolfSSL build..."
+    apt-get update -qq
+    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq autoconf automake libtool
+fi
+
 # Clean up previous builds
 rm -rf /tmp/wolfssl-vuln /tmp/wolfssl-fixed /tmp/forge-vuln /tmp/forge-fixed
 
