@@ -92,0 +131,23 @@
+
+cleanup_dir() {
+    local target=$1
+
+    [ -e "$target" ] || return 0
+    rm -rf "$target" 2>/dev/null && return 0
+
+    if command -v sudo >/dev/null 2>&1; then
+        sudo -n rm -rf "$target" 2>/dev/null && return 0
+    fi
+
+    if docker image inspect "$MYSQL_IMAGE" >/dev/null 2>&1; then
+        docker run --rm \
+            -v "$target:/cleanup" \
+            --entrypoint sh \
+            "$MYSQL_IMAGE" \
+            -c 'chmod -R a+rwX /cleanup' >/dev/null 2>&1 || true
+        rm -rf "$target" 2>/dev/null && return 0
+    fi
+
+    rm -rf "$target"
+}
