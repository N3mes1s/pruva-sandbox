@@ -51 +65,6 @@
-import base64, json, urllib.request, sys
+import base64, json, sys, time
+
+import requests
+import rsa
+from Crypto.Cipher import AES
+from Crypto.Util.Padding import unpad
@@ -54 +73,34 @@
-url = f"http://127.0.0.1:{port}/de2api/datasource/validate"
+base = f"http://127.0.0.1:{port}"
+url = f"{base}/de2api/datasource/validate"
+
+def get_token():
+    last = None
+    for _ in range(60):
+        last = requests.get(f"{base}/de2api/dekey", timeout=10).json()
+        dekey = last.get("data")
+        if isinstance(dekey, str) and dekey:
+            break
+        time.sleep(3)
+    else:
+        raise RuntimeError(f"dekey unavailable: {last}")
+    sep = base64.b64encode(b"-pk_separator-").decode()
+    parts = dekey.split(sep + "=")
+    if len(parts) != 2:
+        parts = dekey.split(sep)
+    k1, k2 = parts[0], parts[1]
+    cipher = AES.new(k2.encode("utf-8"), AES.MODE_CBC, b"0000000000000000")
+    pk = unpad(cipher.decrypt(base64.b64decode(k1)), AES.block_size).decode()
+    pubkey = rsa.PublicKey.load_pkcs1_openssl_pem(
+        ("-----BEGIN PUBLIC KEY-----\n" + pk + "\n-----END PUBLIC KEY-----").encode()
+    )
+    name = base64.b64encode(rsa.encrypt(b"admin", pubkey)).decode()
+    pwd = base64.b64encode(rsa.encrypt(b"DataEase@123456", pubkey)).decode()
+    resp = requests.post(
+        f"{base}/de2api/login/localLogin",
+        json={"name": name, "pwd": pwd, "origin": 0},
+        timeout=10,
+    )
+    data = resp.json()
+    if data.get("code") != 0 or not data.get("data"):
+        raise RuntimeError(resp.text)
+    return data["data"]["token"]
