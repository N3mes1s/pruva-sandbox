--- repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
+++ repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
@@ -8,6 +8,13 @@
 
 cd "$ROOT"
 
+# Install PHP when the base sandbox lacks it.
+if ! command -v php >/dev/null 2>&1; then
+    echo "[*] Installing PHP..."
+    apt-get update -qq
+    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq php-cli php-xml php-mbstring
+fi
+
 REPO="$ROOT/yii2-repo"
 SAFE_FILE="$ROOT/views/safe.php"
 SECRET_FILE="$ROOT/views/secret.txt"
