+# Install Go when the base sandbox lacks it.
+if ! command -v go >/dev/null 2>&1; then
+    echo "[*] Installing Go toolchain..."
+    apt-get update -qq
+    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq golang-go
+fi
+
