--- repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
+++ repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
@@ -6,6 +6,14 @@
 LOGS="$ROOT/logs"
 mkdir -p "$LOGS"
 
+# Install a current Rust toolchain when the base sandbox lacks cargo/rustc.
+if ! command -v cargo >/dev/null 2>&1 || ! command -v rustc >/dev/null 2>&1; then
+    echo "[*] Installing Rust toolchain..."
+    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs -o /tmp/rustup-init.sh
+    sh /tmp/rustup-init.sh -y --profile minimal --default-toolchain stable
+fi
+export PATH="$HOME/.cargo/bin:$PATH"
+
 REPRO_CRATE="$ROOT/repro_crate"
 WORKTREE_DIR="$REPRO_CRATE/worktree"
 FORBIDDEN_DIR="$REPRO_CRATE/forbidden"
