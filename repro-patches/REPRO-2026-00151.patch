--- repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
+++ repro/reproduction_steps.sh	2026-05-28 00:00:00.000000000 +0000
@@ -8,6 +8,14 @@
 
 cd "$ROOT"
 
+# Install PHP/Composer runtime dependencies when the base sandbox lacks them.
+if ! command -v php >/dev/null 2>&1 || ! command -v composer >/dev/null 2>&1; then
+    echo "[*] Installing PHP and Composer..."
+    apt-get update -qq
+    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
+        php-cli php-xml php-mbstring php-curl php-zip php-gd composer
+fi
+
 # Clean up previous runs
 rm -rf "$ROOT/vulnerable" "$ROOT/fixed"
 mkdir -p "$ROOT/vulnerable"
